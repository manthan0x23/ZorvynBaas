{
  "name": "fdp-acb",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rimraf dist && tsc",
    "start": "node dist/app.js",
    "test": "pnpm build && jest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:up": "docker compose -f src/db/postgres/docker-compose.yml up -d",
    "db:down": "docker compose -f src/db/postgres/docker-compose.yml down && rm -rf src/db/postgres/postgres-data",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "argon2": "^0.44.0",
    "dotenv": "^17.4.0",
    "drizzle-orm": "0.45.2",
    "express": "^5.2.1",
    "nanoid": "^5.1.7",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.45.2"
    }
  }
}
