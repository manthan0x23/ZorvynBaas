{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",

    "rootDirs": ["./src", "vitest.config.ts"],
    "outDir": "./dist",

    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },

    "strict": true,
    "esModuleInterop": true,

    "ignoreDeprecations": "6.0",

    "typeRoots": ["./node_modules/@types", "./src/types"],
    "skipLibCheck": true
  },
  "include": ["src", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
